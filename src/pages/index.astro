---
import SiteLayout from "@layouts/SiteLayout.astro"
import Link from "../components/Link.astro"

import GitHub from "../components/icons/GitHub.astro"
import LinkedIn from "../components/icons/LinkedIn.astro"
---

<SiteLayout>
  <header
    class="my-6 flex flex-col items-center justify-around gap-8 text-center sm:flex-row sm:gap-0 sm:text-left"
  >
    <div class="order-last font-sans sm:order-first">
      <div class="mb-4">
        <h1 class="mb-2 text-4xl font-bold tracking-tight">Debashis Biswas</h1>
        <p class="text-lg">Software engineer, musician</p>
      </div>

      <p class="text-lg">debashis [at] dbiswas [dot] com</p>
      <div class="mt-4 flex flex-col items-center gap-3 text-sm sm:items-start">
        <div class="flex items-center gap-4">
          <Link href="https://github.com/debashisbiswas/">
            <GitHub size={20} />
          </Link>

          <Link href="https://www.linkedin.com/in/d-biswas/">
            <LinkedIn size={20} />
          </Link>
        </div>
      </div>
    </div>

    <div class="flex justify-center">
      <!-- Avoiding the Image component as it makes my image too blurry. -->
      <img
        src="/assets/headshot_500x500.webp"
        alt="My headshot!"
        width="256"
        height="256"
        class="rounded-lg"
      />
    </div>
  </header>

  <section class="mb-12 space-y-4">
    <p>Hi, I'm Debashis. I'm a software engineer focused on both systems and web programming.</p>

    <p>
      I'm currently working on software for aircraft testing at Honeywell. I work on device drivers
      for custom hardware on avionics test benches, as well as data pipelines and web interfaces for
      translating and visualizing aircraft hardware configuration data. I previously worked at
      Garmin, Intel, led an engineering team at <Link href="https://github.com/knights-of-academia"
        >The KOA Foundation</Link
      >, and consulted at a few startups.
    </p>

    <p>
      I completed my MS in Computer Science at Arizona State University, where I primarily studied
      cybersecurity: binary analysis and exploitation, reverse engineering, and network security.
    </p>
    <p>
      <Link href="https://www.youtube.com/live/1t8fU8YPe2c?t=2991" />I'm also a classically-trained
      clarinetist, and I completed my BMus in Clarinet Performance at Arizona State University. I've
      studied with
      <Link href="https://www.selmer.fr/en/blogs/artistes/robert-spring">Dr. Robert Spring</Link>,
      <Link href="https://www.selmer.fr/en/blogs/artistes/joshua-gardner">Dr. Joshua Gardner</Link>,
      and
      <Link href="https://www.selmer.fr/en/blogs/artistes/stefanie-gardner"
        >Dr. Stefanie Gardner</Link
      >. In addition to the clarinet, I play the bass clarinet, <Link
        href="https://youtu.be/KwNCOsgOrek"
        target="_blank">contra-alto clarinet</Link
      >, and <Link href="https://youtu.be/feMnKts7Vf0" target="_blank">contrabass clarinet</Link>. I
      also studied instrument repair with Dr. Steve Prescott and actively repair clarinets.
    </p>
  </section>
</SiteLayout>
